    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.0",
    "jose": "^6.2.2",
    "postgres": "^3.4.8",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
