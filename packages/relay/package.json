{
  "name": "@tadaima/relay",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --require dotenv/config src/index.ts",
    "lint": "eslint src/ --ignore-pattern src/__tests__/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
