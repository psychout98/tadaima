<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Entitlements for Tadaima.app and the embedded Node.js runtimes.

  allow-unsigned-executable-memory: Required by V8's JIT compiler
  (Node.js allocates and executes dynamically generated machine code).

  disable-library-validation: Required so the hardened runtime doesn't
  reject unsigned shared libraries that may be loaded by native Node
  modules (e.g. .node addon files).
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
