<?xml version="1.0" encoding="utf-8"?>
<!--
  Distribution definition for Tadaima-Setup.pkg.

  This wraps the single component .pkg (Tadaima.app under /Applications)
  into a distribution-style installer so we can attach a postinstall
  script. The app installs to /Applications (system domain only) because
  the postinstall script hardcodes that path for runtime setup, service
  registration, and config GUI launch.
-->
<installer-gui-script minSpecVersion="2">
    <title>Tadaima</title>
    <organization>com.tadaima</organization>
    <domains enable_localSystem="true"/>
    <options customize="never" require-scripts="true" rootVolumeOnly="true"/>
    <pkg-ref id="com.tadaima.app"
             version="0.1.0"
             onConclusion="none">Tadaima.pkg</pkg-ref>
    <choices-outline>
        <line choice="default">
            <line choice="com.tadaima.app"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="com.tadaima.app" visible="false">
        <pkg-ref id="com.tadaima.app"/>
    </choice>
</installer-gui-script>
