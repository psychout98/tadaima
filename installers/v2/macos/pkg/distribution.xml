<?xml version="1.0" encoding="utf-8"?>
<!--
  Distribution definition for Tadaima-Setup.pkg.

  This wraps the single component .pkg (Tadaima.app under /Applications)
  into a distribution-style installer. The pkg is a pure payload
  delivery mechanism — no scripts. All setup happens in the menu bar
  app's first-launch flow (FirstRunSetup.swift).
-->
<installer-gui-script minSpecVersion="2">
    <title>Tadaima</title>
    <organization>com.tadaima</organization>
    <domains enable_localSystem="true"/>
    <options customize="never" rootVolumeOnly="true"/>
    <pkg-ref id="com.tadaima.app"
             version="0.1.0"
             onConclusion="none">Tadaima.pkg</pkg-ref>
    <choices-outline>
        <line choice="default">
            <line choice="com.tadaima.app"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="com.tadaima.app" visible="false">
        <pkg-ref id="com.tadaima.app"/>
    </choice>
</installer-gui-script>
