<Window
    x:Class="Tadaima.Tray.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Tadaima Settings">

    <StackPanel Padding="24" Spacing="12">
        <TextBlock Text="Tadaima Settings" FontSize="20" FontWeight="SemiBold"/>
        <TextBox x:Name="RelayUrlBox" Header="Relay URL"/>
        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="MoviesDirBox" Header="Movies Directory"/>
            <Button Grid.Column="1" VerticalAlignment="Bottom" Click="OnChooseMovies" Content="Choose…"/>
        </Grid>
        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="TvDirBox" Header="TV Shows Directory"/>
            <Button Grid.Column="1" VerticalAlignment="Bottom" Click="OnChooseTv" Content="Choose…"/>
        </Grid>
        <NumberBox x:Name="MaxDownloadsBox"
                   Header="Max concurrent downloads"
                   Minimum="1" Maximum="8"
                   SpinButtonPlacementMode="Inline"/>
        <ToggleSwitch x:Name="StartOnLoginToggle" Header="Start Tadaima agent on login"/>
        <TextBlock x:Name="StatusText" Foreground="Red"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Save" Click="OnSave" Style="{StaticResource AccentButtonStyle}"/>
        </StackPanel>
    </StackPanel>
</Window>
