#!/bin/bash
# Tadaima Agent — macOS installer preflight script
# Downloads the latest agent binary from GitHub Releases and verifies its checksum.

set -e

REPO="psychout98/tadaima"

ARCH=$(uname -m)
if [ "$ARCH" = "arm64" ]; then
  ASSET="tadaima-agent-darwin-arm64"
else
  ASSET="tadaima-agent-darwin-x64"
fi

# Get the latest release tag
LATEST=$(curl -sL "https://api.github.com/repos/${REPO}/releases/latest" \
  | python3 -c "import sys,json; print(json.load(sys.stdin)['tag_name'])")
if [ -z "$LATEST" ]; then
  osascript -e 'display alert "Download Failed" message "Could not determine the latest release. Check your internet connection." as critical'
  exit 1
fi

# Download binary
curl -fSL -o /tmp/tadaima-agent \
  "https://github.com/${REPO}/releases/download/${LATEST}/${ASSET}" || {
  osascript -e 'display alert "Download Failed" message "Could not download the agent binary. Check your internet connection." as critical'
  exit 1
}

# Download and verify checksum
curl -fSL -o /tmp/checksums.sha256 \
  "https://github.com/${REPO}/releases/download/${LATEST}/checksums.sha256" || {
  osascript -e 'display alert "Download Failed" message "Could not download checksums. Check your internet connection." as critical'
  rm -f /tmp/tadaima-agent
  exit 1
}

EXPECTED=$(grep "${ASSET}" /tmp/checksums.sha256 | awk '{print $1}')
ACTUAL=$(shasum -a 256 /tmp/tadaima-agent | awk '{print $1}')

if [ "$EXPECTED" != "$ACTUAL" ]; then
  osascript -e 'display alert "Download Failed" message "Checksum verification failed. The download may be corrupted. Please try again." as critical'
  rm -f /tmp/tadaima-agent /tmp/checksums.sha256
  exit 1
fi

chmod +x /tmp/tadaima-agent
rm -f /tmp/checksums.sha256
