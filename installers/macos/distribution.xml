<?xml version="1.0" encoding="UTF-8"?>
<installer-gui-script minSpecVersion="2">
    <title>Tadaima Agent</title>
    <organization>com.tadaima</organization>
    <welcome file="welcome.html" />
    <license file="license.html" />
    <conclusion file="conclusion.html" />

    <options customize="never" require-scripts="true" rootVolumeOnly="true" />

    <choices-outline>
        <line choice="default">
            <line choice="com.tadaima.menu" />
            <line choice="com.tadaima.agent" />
        </line>
    </choices-outline>

    <choice id="default" />
    <choice id="com.tadaima.menu"
            visible="false"
            title="Tadaima Menu Bar"
            description="Menu bar status app for the Tadaima agent.">
        <pkg-ref id="com.tadaima.menu" />
    </choice>
    <choice id="com.tadaima.agent"
            visible="false"
            title="Tadaima Agent"
            description="Downloads and installs the Tadaima download agent.">
        <pkg-ref id="com.tadaima.agent" />
    </choice>

    <pkg-ref id="com.tadaima.menu"
             version="1.0.0"
             onConclusion="none">menubar.pkg</pkg-ref>
    <pkg-ref id="com.tadaima.agent"
             version="1.0.0"
             onConclusion="none">component.pkg</pkg-ref>
</installer-gui-script>
